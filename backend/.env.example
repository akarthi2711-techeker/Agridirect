# Server
PORT=5000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=agridirect_user
DB_PASSWORD=your_strong_password_here
DB_NAME=agridirect_db

# JWT
JWT_SECRET=your_jwt_secret_key_min_32_chars_here
JWT_EXPIRES_IN=7d

# AWS
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=ap-south-1
AWS_S3_BUCKET=agridirect-product-images

# AI Market Advisor (API Gateway URL that invokes the Lambda)
AI_LAMBDA_URL=https://xxxxxxxxxx.execute-api.ap-south-1.amazonaws.com/prod/ai/chat
AI_API_GATEWAY_KEY=your_api_gateway_key_here

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
