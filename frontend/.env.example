# ─────────────────────────────────────────────────────────
# AgriDirect Frontend — Environment Variables
# Copy this file to .env.local for local dev
# Set these in Vercel dashboard for production
# ─────────────────────────────────────────────────────────

# Single API Gateway URL — all requests go here.
# API Gateway routes:
#   /ai/*        → Lambda (Bedrock AI advisor)
#   /market/*    → Lambda (DynamoDB market prices)
#   /crop/*      → Lambda (crop recommendations)
#   /chat/*      → Lambda (chat history)
#   everything else → EC2 Express (HTTP proxy integration)
#
# Replace with your actual API Gateway invoke URL:
REACT_APP_API_URL=https://xxxxxxxxxx.execute-api.ap-south-1.amazonaws.com/prod

# Local development (Express server running locally):
# REACT_APP_API_URL=http://localhost:5000/api
